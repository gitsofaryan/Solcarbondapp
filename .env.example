# SolCarbon dApp – environment variable template
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# --------------------------------------------------------------------
# Treasury keypair (Base58-encoded 64-byte Ed25519 secret key).
#
# ⚠️  SECURITY WARNING ⚠️
# This key controls the treasury wallet that holds SOL reserves and
# acts as the SPL mint authority.  In production it must be kept in a
# server-side secrets manager (AWS Secrets Manager, HashiCorp Vault,
# etc.) and NEVER embedded in client-side code or committed to git.
#
# For local devnet development only, paste the Base58 secret key here.
# The app will fall back to the hard-coded devnet key if this is unset.
# --------------------------------------------------------------------
TREASURY_SECRET_KEY=<your-base58-encoded-64-byte-secret-key>
